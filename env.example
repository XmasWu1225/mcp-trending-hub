# API配置
# 请复制此文件为 .env 并填入你的API密钥
FIRECRAWL_API_KEY=your-api-key-here
TRENDS_HUB_CUSTOM_RSS_URL=https://your-rss-feed-url.com/feed

# 服务器配置（可选）
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# MCP_PATH=/mcp
# MCP_LOG_LEVEL=INFO

# HTTP配置（可选）
# HTTP_TIMEOUT=30.0
# HTTP_FOLLOW_REDIRECTS=true

# 缓存配置（可选）
# CACHE_DIR=
# CACHE_DURATION_MINUTES=30